<div class="container-small">
  <a href="<%=root_path%>" class="back-button">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M6.75 15.75L3 12M3 12L6.75 8.25M3 12H21" stroke="var(--icon-color)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span>All events</span>
  </a>
  <div class="event-detail <%= "past_event-detail" if @event.past? %>">
    <div class="event-detail__time-and-location">
      <%= formated_event_date_time(@event.date, @event.time, "event-detail__time") %>
      <%= tag.div @event.location, class: "event-detail__location"%>
    </div>
    <%= tag.h1 @event.title, class: "event-detail__title"%>
    <div data-controller="guest-list">
      <%  if @event.attendees.include?(Current.user)%>
        <div class="event-details__invitation">
          <%= render "cancle-attendance-button", invitation: @invitation, event: @event unless @event.past? %>
          <%= render "number_of_attendees_including_you", attendees: @attendees %>
        </div>
      <% else %>
        <div class="event-details__invitation">
          <%= render "attend-button", invitation: @invitation, event: @event unless @event.past? %>
          <%= render "number_of_attendees", attendees: @attendees %>
        </div>
      <% end %>
      <%= render "guest_list", attendees: @attendees %>
    </div>
    <%= tag.p @event.description, class: "event-detail__description"%>
    <div class="event-detail_host">
      hosted by 
      <%=  @event.host == Current.user ? "You" : @event.host.username%>
    </div>
  </div>
  <% if authenticated? && @event.host == Current.user%>
    <div class="event-detail__edit-buttons">
      <%= link_to "Edit", edit_event_path(@event), class: "button" %>
      <%= button_to "Delete", @event, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this event?" }, class: "button button--danger" %>
    </div>
  <%end%>
</div>
