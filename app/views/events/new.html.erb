<%= form_with model: @event do |form| %>
  <%= form.text_field :title, required: true, autofocus: true, placeholder: "Type your event’s name" %>
  <%= form.text_area :description, required: true, size: '50x12', placeholder: "Type your event’s description" %>
  <%= form.date_field :date, required: true %>
  <%= form.time_field :time, required: true %>
  <%= form.text_field :location, required: true %>
  <%= form.button "Create Event", class: "button button-primary"  %>
  <%= form.submit "Create Event", class: "button button-primary"  %>
<% end %>